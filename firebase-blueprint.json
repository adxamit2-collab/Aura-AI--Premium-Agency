{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and role information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastVisit": { "type": "string", "format": "date-time" },
        "interests": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "Lead": {
      "title": "Lead",
      "description": "A potential client lead, qualified by AI.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "company": { "type": "string" },
        "message": { "type": "string" },
        "intentScore": { "type": "number", "description": "AI generated score from 1-100" },
        "aiSummary": { "type": "string", "description": "AI generated summary of the lead" },
        "status": { "type": "string", "enum": ["new", "contacted", "qualified", "archived"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "message", "status", "createdAt"]
    },
    "ChatSession": {
      "title": "Chat Session",
      "description": "A conversation between a user and the AI assistant.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Optional user ID if logged in" },
        "sessionId": { "type": "string", "description": "Anonymous session ID" },
        "messages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "role": { "type": "string", "enum": ["user", "model"] },
              "text": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["sessionId", "messages", "createdAt", "updatedAt"]
    },
    "ContentSuggestion": {
      "title": "Content Suggestion",
      "description": "AI-generated content ideas for the website.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["blog", "headline", "offer"] },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "published", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "title", "content", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "/leads/{leadId}": {
      "schema": { "$ref": "#/entities/Lead" },
      "description": "Stores qualified leads."
    },
    "/chats/{chatId}": {
      "schema": { "$ref": "#/entities/ChatSession" },
      "description": "Stores AI chat sessions."
    },
    "/content_suggestions/{suggestionId}": {
      "schema": { "$ref": "#/entities/ContentSuggestion" },
      "description": "Stores AI content suggestions."
    }
  }
}
