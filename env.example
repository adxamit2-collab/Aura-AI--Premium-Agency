import { useState, useEffect } from 'react';
import { motion } from 'motion/react';
import { ArrowRight, Sparkles, Zap, ShieldCheck } from 'lucide-react';
import ContactForm from '../components/ContactForm';

export default function Home() {
  const [isReturningUser, setIsReturningUser] = useState(false);

  useEffect(() => {
    const visited = localStorage.getItem('hasVisited');
    if (visited) {
      setIsReturningUser(true);
    } else {
      localStorage.setItem('hasVisited', 'true');
    }
  }, []);

  return (
    <div className="bg-stone-50">
      {/* Hero Section */}
      <section className="relative pt-32 pb-20 lg:pt-48 lg:pb-32 overflow-hidden">
        <div className="absolute inset-0 bg-[url('https://picsum.photos/seed/architecture/1920/1080?blur=10')] bg-cover bg-center opacity-10 mix-blend-multiply"></div>
        <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
          <motion.div
            initial={{ opacity: 0, y: 30 }}
            animate={{ opacity: 1, y: 0 }}
            transition={{ duration: 0.8, ease: "easeOut" }}
            className="text-center max-w-3xl mx-auto"
          >
            <h1 className="text-5xl md:text-7xl font-serif font-bold text-stone-900 leading-tight mb-6">
              {isReturningUser ? 'Welcome back to Aura.' : 'Elevate your brand with AI.'}
            </h1>
            <p className="text-lg md:text-xl text-stone-600 mb-10 font-light">
              {isReturningUser 
                ? 'Ready to continue your digital transformation? Let\'s build something extraordinary together.'
                : 'We blend premium European design with cutting-edge Google AI to create digital experiences that convert.'}
            </p>
            <div className="flex flex-col sm:flex-row justify-center gap-4">
              <button className="bg-stone-900 text-white px-8 py-4 rounded-full text-sm font-medium hover:bg-stone-800 transition-all flex items-center justify-center group">
                Start a Project
                <ArrowRight size={16} className="ml-2 group-hover:translate-x-1 transition-transform" />
              </button>
              <button className="bg-white text-stone-900 border border-stone-200 px-8 py-4 rounded-full text-sm font-medium hover:bg-stone-50 transition-all">
                View Our Work
              </button>
            </div>
          </motion.div>
        </div>
      </section>

      {/* Features Section */}
      <section className="py-24 bg-white">
        <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div className="grid grid-cols-1 md:grid-cols-3 gap-12">
            <motion.div 
              whileHover={{ y: -5 }}
              className="p-8 rounded-3xl bg-stone-50 border border-stone-100"
            >
              <div className="w-12 h-12 bg-stone-900 text-white rounded-2xl flex items-center justify-center mb-6">
                <Sparkles size={24} />
              </div>
              <h3 className="text-xl font-serif font-bold mb-3">AI Personalization</h3>
              <p className="text-stone-600 text-sm leading-relaxed">
                Dynamic content that adapts to user behavior, increasing engagement and conversion rates automatically.
              </p>
            </motion.div>

            <motion.div 
              whileHover={{ y: -5 }}
              className="p-8 rounded-3xl bg-stone-50 border border-stone-100"
            >
              <div className="w-12 h-12 bg-stone-900 text-white rounded-2xl flex items-center justify-center mb-6">
                <Zap size={24} />
              </div>
              <h3 className="text-xl font-serif font-bold mb-3">Ultra-Fast Performance</h3>
              <p className="text-stone-600 text-sm leading-relaxed">
                Optimized for Core Web Vitals. Lightning-fast load times that keep your users engaged and improve SEO.
              </p>
            </motion.div>

            <motion.div 
              whileHover={{ y: -5 }}
              className="p-8 rounded-3xl bg-stone-50 border border-stone-100"
            >
              <div className="w-12 h-12 bg-stone-900 text-white rounded-2xl flex items-center justify-center mb-6">
                <ShieldCheck size={24} />
              </div>
              <h3 className="text-xl font-serif font-bold mb-3">GDPR Compliant</h3>
              <p className="text-stone-600 text-sm leading-relaxed">
                Enterprise-grade security and strict adherence to EU privacy standards. Your data is safe with us.
              </p>
            </motion.div>
          </div>
        </div>
      </section>

      {/* Smart Lead System Section */}
      <section className="py-24 bg-stone-900 text-white relative overflow-hidden">
        <div className="absolute top-0 left-0 w-full h-full overflow-hidden pointer-events-none">
          <div className="absolute -top-1/2 -right-1/4 w-[1000px] h-[1000px] rounded-full bg-stone-800/50 blur-3xl"></div>
        </div>
        <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
          <div className="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <div>
              <h2 className="text-4xl md:text-5xl font-serif font-bold mb-6">Let's build the future.</h2>
              <p className="text-stone-400 text-lg mb-8 font-light">
                Our AI-powered lead system ensures we understand your needs before we even speak. Fill out the form, and our intelligent system will prioritize your request.
              </p>
              <ul className="space-y-4 text-sm text-stone-300">
                <li className="flex items-center"><ArrowRight size={16} className="mr-3 text-white" /> Smart qualification</li>
                <li className="flex items-center"><ArrowRight size={16} className="mr-3 text-white" /> Instant AI analysis</li>
                <li className="flex items-center"><ArrowRight size={16} className="mr-3 text-white" /> Priority routing</li>
              </ul>
            </div>
            <div className="bg-white text-stone-900 p-8 rounded-3xl shadow-2xl">
              <ContactForm />
            </div>
          </div>
        </div>
      </section>
    </div>
  );
}
